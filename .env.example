# Kanban Board example environment
# Copy this file to .env and replace placeholder values before running.

# Domain / app URLs
DOMAIN=kanbanboard.com.tr
FRONTEND_HOST=http://kanbanboard.com.tr
ENVIRONMENT=local
PROJECT_NAME="Kanban Board"
STACK_NAME=kanban-board

# CORS origins used by the FastAPI backend
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:5173","http://localhost:3000","http://kanbanboard.com.tr","http://dashboard.kanbanboard.com.tr","http://api.kanbanboard.com.tr","https://kanbanboard.com.tr","https://dashboard.kanbanboard.com.tr","https://api.kanbanboard.com.tr"]

# Security / initial admin
SECRET_KEY=change-this-secret-key
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-this-admin-password

# PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379

# Email / SMTP
SMTP_HOST=smtp.example.com
SMTP_USER=mailer@example.com
SMTP_PASSWORD=change-this-smtp-password
EMAILS_FROM_EMAIL=mailer@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# OAuth / Google login
# Add this callback URL in Google Cloud Console:
# http://api.kanbanboard.com.tr/api/v1/oauth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Docker image names
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# Optional integrations
SENTRY_DSN=
CLOUDFLARE_TUNNEL_TOKEN=
CF_DNS_API_TOKEN=

# Traefik dashboard basic auth
USERNAME=admin
HASHED_PASSWORD=replace-with-htpasswd-hash
